# STRIPE (tarjeta de crédito/débito)
# Obtén en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_TU_SECRET_KEY_AQUI
STRIPE_PUBLISHABLE_KEY=pk_test_TU_PUBLISHABLE_KEY_AQUI
STRIPE_WEBHOOK_SECRET=whsec_TU_WEBHOOK_AQUI

# PAYPAL
# Obtén en: https://developer.paypal.com/dashboard/applications/live
PAYPAL_CLIENT_ID=TU_CLIENT_ID_AQUI
PAYPAL_SECRET=TU_SECRET_AQUI

# EMAIL (Gmail para enviar el PDF automáticamente)
# Activa "App Passwords" en tu cuenta Google
# https://myaccount.google.com/apppasswords
EMAIL_FROM=tu@gmail.com
EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_SMTP=smtp.gmail.com

# Puerto del servidor
PORT=5000
